# ─── The Peptide Alliance — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@peptidealliance.io

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_VERIFIED_PRICE_ID=price_...
STRIPE_FEATURED_PRICE_ID=price_...
STRIPE_INDUSTRY_LEADER_PRICE_ID=price_...

# ── Google Places (optional) ──────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ── Error Tracking (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── Security ──────────────────────────────────────────────────────────────────
IP_HASH_SALT=change-me-to-a-random-string
